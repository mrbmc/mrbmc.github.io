<header id="masthead">

{{#if masthead.image}}

    <h1>{{title}}</h1>

    <figure>
        <img data-parallax="25" src="{{masthead.image}}" alt="{{masthead.caption}}">
        {{#if masthead.caption}}<figcaption>{{masthead.caption}}</figcaption>{{/if}}
    </figure>

    <svg version="1.1" id="scrollhint" data-scrolltarget="main" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" width="60px" height="20px" viewBox="0 0 53 20" enable-background="new 0 0 53 20" xml:space="preserve"><g><polygon points="26.5,17.688 9.114,3.779 10.303,2.312 26.5,15.269 42.697,2.313 43.886,3.779"></polygon></g></svg>

{{ else }}

	<div class="container">
		<h1>{{title}}</h1>
	</div>

{{/if}}

</header>

<div id="main">
    {{#if pubDate}}<h4 class="date">Published {{pubDate}}</h4>{{/if}}
    {{#if content}}{{{content}}}{{/if}}
</div>


<nav class="pagination">
    <a href="/blog/#/-" class="prev">Previous</a>
    {{!-- <a href="/blog/">Blog Home</a> --}}
    <a href="/blog/#/+" class="next">Next</a>
</nav>
